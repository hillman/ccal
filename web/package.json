{
  "name": "ccal-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "ccal PWA — a full Automerge peer in the browser, served by ccal-server",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "spike": "node spike/spike.mjs",
    "conformance": "node --experimental-strip-types test/conformance.ts"
  },
  "dependencies": {
    "@automerge/automerge": "^2.2.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.2",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.4.1",
    "ws": "^8.18.0"
  }
}
